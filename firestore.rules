rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Same rules you'll deploy to production (see tools/firestore-rules-recommended.txt).
    // The seed script creates a staff login (admin@blackstars.qa / admin123) in the
    // Auth emulator so the app can sign in and write.
    function isMember() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.matches('.*@(blackstars[.]com|members[.]blackstars[.]qa)$');
    }
    function isStaff() {
      return request.auth != null && !isMember();
    }

    match /clubs/{clubId} {
      allow read:  if request.auth != null;
      allow write: if isStaff();

      // AUDIT TRAIL is IMMUTABLE (req #8): staff may CREATE audit entries and
      // everyone signed-in may READ them, but NOBODY may update or delete them.
      // (Firestore grants if ANY matching rule allows, so this must be declared
      // BEFORE the generic collection rule AND the generic rule must exclude
      // 'auditLog' — otherwise the broad allow-write would re-permit deletes.)
      match /auditLog/{docId} {
        allow read:   if request.auth != null;
        allow create: if isStaff();
        allow update, delete: if false;
      }

      // Every OTHER per-record subcollection: staff read/write, members read-only.
      match /{collection}/{docId} {
        allow read:  if request.auth != null;
        allow write: if isStaff() && collection != 'auditLog';
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
